parameters:
	ignoreErrors:
		-
			message: "#^Unsafe usage of new static\\(\\)\\.$#"
			count: 1
			path: src/Controller/AdminAnnotationListController.php

		-
			message: "#^Unsafe usage of new static\\(\\)\\.$#"
			count: 1
			path: src/Controller/AnnotationController.php

		-
			message: "#^Unsafe usage of new static\\(\\)\\.$#"
			count: 1
